</head>


 <body class="h-full m-0 p-0 overflow-x-hidden lg:overflow-hidden">
  <div id="app-container" class="min-h-screen lg:h-full h-auto w-full flex flex-col" style="background: #F5F1EB;"
>

<!-- Title Bar / Header -->
   <header class="flex items-center justify-between px-6 py-4 border-b" style="background: #1E40AF
; border-color: #1E40AF;">
    <div class="flex tems-center gap-3">
      
      <!-- School Logo --> <img src="ths.jpg" alt="Taal High School Logo" loading="lazy" class="w-10 h-10 rounded-lg object-cover" onerror="console.error('Image failed to load:', this.src); this.style.background='linear-gradient(135deg, #2E7D32
, #8b5cf6)'; this.alt='Logo unavailable';">
<div>
      <h1 id="app-title" class="text-lg font-semibold" style="color: white;">Taal High School</h1>
      <p class="text-xs" style="color: white;">Parent Connect</p>
     </div>
    </div>

<!-- Window Controls (decorative) -->
    <div class="flex items-center gap-2"><button class="w-3 h-3 rounded-full transition-opacity hover:opacity-80" style="background: #fbbf24;"></button> <button class="w-3 h-3 rounded-full transition-opacity hover:opacity-80" style="background: #22c55e;"></button> <button class="w-3 h-3 rounded-full transition-opacity hover:opacity-80" style="background: #ef4444;"></button>
    </div>

</header>

<!-- Main Content Area -->
   <main class="flex-1 flex flex-col lg:flex-row overflow-y-auto lg:overflow-hidden">

<!-- Left Panel - Compose Message -->
    <section class="w-full lg:w-1/2 p-4 sm:p-6 flex flex-col border-b lg:border-b-0 lg:border-r" style="border-color: #334155;">

<!-- Recipients Section -->
     <div class="mb-5"><label class="block text-sm font-medium mb-3" style="color: #94a3b8;"> <span class="flex items-center gap-2">
        <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />  <circle cx="9" cy="7" r="4" /> <path d="M23 21v-2a4 4 0 0 0-3-3.87" /> <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg> Recipients </span> </label> 

<!-- Recipients Options (Radio Button) -->
      <div class="space-y-3 mb-4"><label class="flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-all hover:opacity-90" style="background: #FAFAFA; border: 1px solid #CD999A;"> <input type="radio" name="recipient-type" value="all" id="radio-all" checked class="w-4 h-4 accent-indigo-500" style="cursor: pointer;"> 
      <span class="text-sm font-medium" style="color: #8E204D;"> All Students </span> </label> <label class="flex items-center gap-3 p-3 rounded-lg cursor-pointer transition-all hover:opacity-90" style="background: #FAFAFA; border: 1px solid #CD999A;"> <input type="radio" name="recipient-type" value="grade" id="radio-grade" class="w-4 h-4 accent-indigo-500" style="cursor: pointer;"> <span class="text-sm font-medium" style="color: #8E204D;">By Grade Level</span> </label>
      </div>

<!-- Recipients Selection -->
      <div id="grade-selection" class="space-y-3 hidden">
       <div><label class="block text-xs font-medium mb-2" style="color: #94a3b8;">Select Grade</label> <select id="grade-dropdown" class="w-full px-4 py-3 rounded-lg text-sm transition-all input-focus cursor-pointer" style="background: #FAFAFA; border: 1px solid #CD999A; color: #8E204D;"> <option value="">Choose a grade...</option> <option value="11">Grade 11</option> <option value="12">Grade 12</option> </select>
       </div>
       <div id="section-container" class="hidden"><label class="block text-xs font-medium mb-2" style="color: #94a3b8;">Select Section</label> <select id="section-dropdown" class="w-full px-4 py-3 rounded-lg text-sm transition-all input-focus cursor-pointer" style="background: #FAFAFA; border: 1px solid #CD999A; color: #8E204D;"> <option value="">Choose a section...</option> </select>
       </div>
      </div>
      
  <!-- Selected Recipients Summary -->
      <div id="recipients-summary" class="mt-3 p-3 rounded-lg flex items-center justify-between gap-2" style="background: #DBEAFE; border: 1px solid #93C5FD;">
       <div class="flex items-center gap-2">
        <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="#1E3A8A" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /> <circle cx="8.5" cy="7" r="4" /> <line x1="20" y1="8" x2="20" y2="14" /> <line x1="23" y1="11" x2="17" y2="11" />
        </svg><span id="summary-text" class="text-xs font-medium" style="color: #1E3A8A;">All Senior High School Students Selected</span>
       </div><button id="manage-contacts-btn" class="px-3 py-1.5 rounded text-xs font-medium transition-all hover:opacity-90" style="background: orange; color: #FAFAFA; display: inline-block;"> Manage Contacts </button>
      </div>
     </div>
     
     <!-- Message Compose -->
     <div class="flex-1 flex flex-col mb-5"><label class="block text-sm font-medium mb-2" style="color: #94a3b8;"> <span class="flex items-center gap-2">
        <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /> <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
        </svg> Compose Message </span> </label>
      <div class="flex-1 relative"><textarea id="message-input" placeholder="Type your message here..." class="w-full h-full px-4 py-3 rounded-lg text-sm resize-none transition-all input-focus" style="background: #FAFAFA; border: 1px solid #CD999A; color: #0F0F0F; min-height: 120px;"></textarea>
       <div class="absolute bottom-3 right-3"><span id="char-count" class="text-xs" style="color: #64748b;">87/160</span>
       </div>
      </div>
     </div>
     
  <!-- Action Buttons -->
    <div class="flex items-center gap-3"><button id="send-btn" class="flex-1 flex items-center justify-center gap-2 px-6 py-3.5 rounded-lg font-semibold text-sm text-white transition-all btn-primary" style="background: linear-gradient(135deg, #EC407A, #8b5cf6);">
       <svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13" /> <polygon points="22 2 15 22 11 13 2 9 22 2" />
       </svg><span id="send-btn-text">Send Message</span> </button>
     </div>
    </section>
    
<!-- Right Panel - Message Log Contact List -->
    <section id="right-panel" class="w-full lg:w-1/2 flex flex-col" style="background: #FFFAF0; position: relative;">

<!-- Message Log View -->
     <div id="message-log-view" class="flex flex-col h-full"class="">

<!-- Log Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b" style="border-color: #334155;">
       <div class="flex items-center gap-3">
        <h2 class="text-sm font-semibold" style="color: #006400;">Message Log</h2>
       </div>
      </div>
      
<!-- Stats Bar -->
      <div class="grid grid-cols-4 gap-3 px-6 py-4 border-b" style="border-color: #334155;">
       <div class="text-center cursor-pointer transition-opacity hover:opacity-80" id="filter-total">
        <p class="text-lg font-bold" style="color: #0F0F0F;" id="stat-total">0</p>
        <p class="text-xs font-medium" style="color: #374151;">Total Sent</p>
       </div>
       <div class="text-center cursor-pointer transition-opacity hover:opacity-80" id="filter-delivered">
        <p class="text-lg font-bold" style="color: #22c55e;" id="stat-delivered">0</p>
        <p class="text-xs font-medium" style="color: #374151;">Delivered</p>
       </div>
       <div class="text-center cursor-pointer transition-opacity hover:opacity-80" id="filter-pending">
        <p class="text-lg font-bold" style="color: #fbbf24;" id="stat-pending">0</p></p>
        <p class="text-xs font-medium" style="color: #374151;">Pending</p>
       </div>
       <div class="text-center cursor-pointer transition-opacity hover:opacity-80" id="filter-failed">
        <p class="text-lg font-bold" style="color: #ef4444;" id="stat-failed">0</p>
        <p class="text-xs font-medium" style="color: #374151;">Failed</p>
       </div>
      </div>

<!-- Log Entries -->
      <div id="message-log" class="flex-1 overflow-y-auto px-4 py-3 space-y-2">
      </div>

<!-- Contact List View -->
      <div id="contact-list-view" style="display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(145deg, #f8fbff 0%, #eef4ff 55%, #f8fbff 100%); z-index: 50; flex-direction: column; animation: slideIn 0.3s ease-out;">

<!-- Contact List Header -->
       <div class="flex items-center justify-between px-6 py-4 border-b" style="border-color: #1E3A8A; background: #0B1F5E; backdrop-filter: blur(10px);">
        <div class="flex items-center gap-3">
         <div style="width: 32px; height: 32px; background: linear-gradient(135deg, #EC407A, #8b5cf6); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /> <circle cx="9" cy="7" r="4" /> <path d="M23 21v-2a4 4 0 0 0-3-3.87" /> <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
         </div>
         <h2 class="text-lg font-bold" style="color: #f1f5f9;">Contact Management</h2>
        </div><button id="close-contacts-btn" class="px-4 py-2 rounded-lg text-sm font-medium transition-all hover:opacity-80 hover:scale-105" style="background: rgba(255, 255, 255, 0.2); color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.35);">Close</button>
       </div>

<!-- Contact Columns -->
       <div class="flex-1 flex overflow-hidden">

<!-- Students Column -->
        <div class="flex-1 flex flex-col border-r" style="border-color: #BFDBFE;">
         <div class="px-5 py-4 border-b" style="border-color: #BFDBFE; background: #DBEAFE;">
          <div class="flex items-center justify-between">
           <h3 class="text-base font-bold" style="color: #1E3A8A;">Students</h3>
           <div class="flex items-center gap-2">
            <button id="select-all-students-btn" class="px-3 py-2 rounded-lg text-xs font-semibold transition-all hover:opacity-90 hover:scale-105" style="background: #EAF2FF; color: #1E3A8A; border: 1px solid #93C5FD;">Select All</button><button id="load-students-btn" class="px-4 py-2 rounded-lg text-xs font-semibold transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
             <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /> <polyline points="7 10 12 15 17 10" /> <line x1="12" y1="15" x2="12" y2="3" />
             </svg> Load File </button>
           </div>
          </div>
         </div>
         <div id="students-list" class="flex-1 overflow-y-auto px-4 py-3" style="background: #FAFAFA;">
          <div class="text-center py-8" style="color: #64748b; font-size: 13px;">
           <svg width="48" height="48" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto 12px; opacity: 0.5;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /> <circle cx="9" cy="7" r="4" /> <path d="M23 21v-2a4 4 0 0 0-3-3.87" /> <path d="M16 3.13a4 4 0 0 1 0 7.75" />
           </svg> No students loaded yet<br><span style="font-size: 11px; opacity: 0.7;">Click "Load File" or "Add Student"</span>
          </div>
         </div>
        </div>
  
  <!-- Parents Column -->
        <div class="flex-1 flex flex-col">
         <div class="px-5 py-4 border-b" style="border-color: #BFDBFE; background: #DBEAFE;">
          <div class="flex items-center justify-between">
           <h3 class="text-base font-bold" style="color: #1E3A8A;">Parents</h3>
           <div class="flex items-center gap-2">
            <button id="select-all-parents-btn" class="px-3 py-2 rounded-lg text-xs font-semibold transition-all hover:opacity-90 hover:scale-105" style="background: #EAF2FF; color: #1E3A8A; border: 1px solid #93C5FD;">Select All</button><button id="load-parents-btn" class="px-4 py-2 rounded-lg text-xs font-semibold transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
             <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle; margin-right: 4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /> <polyline points="7 10 12 15 17 10" /> <line x1="12" y1="15" x2="12" y2="3" />
             </svg> Load File </button>
           </div>
          </div>
         </div>
         <div id="parents-list" class="flex-1 overflow-y-auto px-4 py-3" style="background: #FAFAFA;">
          <div class="text-center py-8" style="color: #64748b; font-size: 13px;">
           <svg width="48" height="48" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto 12px; opacity: 0.5;"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /> <circle cx="8.5" cy="7" r="4" /> <polyline points="17 11 19 13 23 9" />
           </svg> No parents loaded yet<br><span style="font-size: 11px; opacity: 0.7;">Click "Load File" or "Add Parent"</span>
          </div>
         </div>
        </div>
       </div>

<!-- Add Contact Form (Hidden by default) -->
       <div id="add-contact-form" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 p-6 rounded-xl shadow-2xl" style="background: linear-gradient(145deg, #ffffff, #f3f8ff); border: 1px solid #BFDBFE; display: none; z-index: 100; min-width: 360px; backdrop-filter: blur(20px);">
        <div class="flex items-center justify-between mb-5">
         <h3 class="text-base font-bold" style="color: #1E3A8A;" id="form-title">Add Contact</h3>
         <div style="width: 28px; height: 28px; background: linear-gradient(135deg, #2563EB, #1E3A8A); border-radius: 6px; display: flex; align-items: center; justify-content: center;">
          <svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /> <circle cx="8.5" cy="7" r="4" /> <line x1="20" y1="8" x2="20" y2="14" /> <line x1="23" y1="11" x2="17" y2="11" />
          </svg>
         </div>
        </div>
        <div class="space-y-4">
         <div><label class="block text-xs font-semibold mb-2" style="color: #1E3A8A;">Full Name</label> <input type="text" id="contact-name-input" class="w-full px-4 py-3 rounded-lg text-sm input-focus font-medium" style="background: #ffffff; border: 1px solid #93C5FD; color: #0F0F0F;" placeholder="e.g Juan Dela Cruz">
         </div>
         <div><label class="block text-xs font-semibold mb-2" style="color: #1E3A8A;">Phone Number</label> <input type="tel" id="contact-phone-input" class="w-full px-4 py-3 rounded-lg text-sm input-focus font-medium" style="background: #ffffff; border: 1px solid #93C5FD; color: #0F0F0F;" placeholder="+63 XXX XXX XXX">
         </div>
         <input type="hidden" id="contact-grade-input" value="">
         <input type="hidden" id="contact-section-input" value="">
         <div class="flex gap-3 pt-3"><button id="save-contact-btn" class="flex-1 px-5 py-3 rounded-lg text-sm font-semibold transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #2563EB, #1E3A8A); color: white; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.35);">Save Contact</button> <button id="cancel-contact-btn" class="flex-1 px-5 py-3 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background: #EAF2FF; color: #1E3A8A; border: 1px solid #BFDBFE;"> Cancel </button>
         </div>
        </div>
       </div>

<!-- Bottom Action Buttons -->
       <div class="px-6 py-4 border-t flex gap-3" style="border-color: #BFDBFE; background: #F5F9FF; backdrop-filter: blur(10px);"><button id="add-student-btn" class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #10b981, #059669); color: white; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
         <svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /> <line x1="5" y1="12" x2="19" y2="12" />
         </svg> Add Student </button> <button id="delete-student-btn" class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #B91C1C, #991B1B); color: white; box-shadow: 0 4px 12px rgba(185, 28, 28, 0.3);">
         <svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6" /> <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
         </svg> Delete </button> <button id="add-parent-btn" class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #10b981, #059669); color: white; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
         <svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /> <line x1="5" y1="12" x2="19" y2="12" />
         </svg> Add Parent </button> <button id="delete-parent-btn" class="flex-1 flex items-center justify-center gap-2 px-4 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105" style="background: linear-gradient(135deg, #B91C1C, #991B1B); color: white; box-shadow: 0 4px 12px rgba(185, 28, 28, 0.3);">
         <svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6" /> <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
         </svg> Delete </button>
       </div>
      </div>
     </div>
    </section>
   </main>

<!-- Schedule Modal removed -->
  </div>
