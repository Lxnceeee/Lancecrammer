      if (recipients.length === 0) {
        alert('Please add contacts and select at least one recipient.');
        showContactList();
        return;
      }

      const phones = recipients
        .map(c => normalizePhone(c.phone))
        .filter(p => p.length >= 7);

      if (phones.length === 0) {
        alert('No valid phone numbers found in selected contacts.');
        showContactList();
        return;
